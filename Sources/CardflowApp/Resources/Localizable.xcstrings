    "onboarding.welcome.title": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Bem-vindo ao Cardflow"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Welcome to Cardflow"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Te damos la bienvenida a Cardflow"
          }
        }
      }
    },
    "onboarding.welcome.subtitle": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Copiar os cartões com segurança, em quatro passos"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Copy your cards safely, in four steps"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Copia las tarjetas con seguridad, en cuatro pasos"
          }
        }
      }
    },
    "onboarding.step1.title": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Conecte o cartão e o disco"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Plug in the card and the drive"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Conecta la tarjeta y el disco"
          }
        }
      }
    },
    "onboarding.step1.text": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Insira o cartão da câmera e ligue o SSD ou HD onde quer salvar a cópia."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Insert the camera card and turn on the SSD or hard drive where you want the copy."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Inserta la tarjeta de la cámara y enciende el SSD o disco duro donde quieres guardar la copia."
          }
        }
      }
    },
    "onboarding.step2.title": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha o destino"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose the destination"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige el destino"
          }
        }
      }
    },
    "onboarding.step2.text": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O app já sugere o maior disco. Confira, e ligue um disco de backup se quiser uma segunda cópia."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The app already suggests the largest drive. Double-check it, and plug in a backup drive if you want a second copy."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La app ya sugiere el disco más grande. Confírmalo y conecta un disco de backup si quieres una segunda copia."
          }
        }
      }
    },
    "onboarding.step3.title": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Inicie e aguarde"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start and wait"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Inicia y espera"
          }
        }
      }
    },
    "onboarding.step3.text": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Clique em Iniciar. O Cardflow copia e confere cada arquivo byte a byte — não desconecte nada enquanto roda."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click Start. Cardflow copies and verifies every file byte by byte, so don’t disconnect anything while it runs."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Haz clic en Iniciar. Cardflow copia y verifica cada archivo byte a byte, así que no desconectes nada mientras trabaja."
          }
        }
      }
    },
    "onboarding.step4.title": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Espere o verde pra formatar"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Wait for the green light to format"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Espera la luz verde para formatear"
          }
        }
      }
    },
    "onboarding.step4.text": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Só formate o cartão quando aparecer “Pode formatar com segurança”. Nunca antes — é o que garante que nada se perdeu."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only format the card once you see “Safe to format”. Never before — that’s what guarantees nothing was lost."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Formatea la tarjeta solo cuando aparezca «Puedes formatear con seguridad». Nunca antes: es lo que garantiza que nada se perdió."
          }
        }
      }
    },
    "onboarding.cta": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Entendi, começar"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Got it, let’s start"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Entendido, empezar"
          }
        }
      }
    },

    "error.offload.notEnoughSpace %@": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não há espaço suficiente em: %@. Libere espaço no destino e tente de novo."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not enough space on: %@. Free up space on the destination and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay espacio suficiente en: %@. Libera espacio en el destino e inténtalo de nuevo."
          }
        }
      }
    },
    "error.offload.unsafeDestination": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este preset tem uma estrutura de pastas inválida (tentou gravar fora da pasta de destino). Edite o preset e tente de novo."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This preset has an invalid folder structure (it tried to write outside the destination folder). Edit the preset and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este preset tiene una estructura de carpetas inválida (intentó escribir fuera de la carpeta de destino). Edita el preset e inténtalo de nuevo."
          }
        }
      }
    },
    "error.offload.cancelled": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Backup cancelado. Os arquivos já copiados estão no destino, mas o backup está incompleto — mantenha o cartão como está."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Backup cancelled. The files already copied are at the destination, but the backup is incomplete — keep the card as is."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Backup cancelado. Los archivos ya copiados están en el destino, pero el backup está incompleto: mantén la tarjeta como está."
          }
        }
      }
    },
    "error.offload.diskFullDuringCopy": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Um disco de destino encheu durante a cópia. Libere espaço e tente de novo. O cartão está intocado — mantenha-o como está."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A destination disk filled up during the copy. Free up space and try again. The card is untouched — keep it as is."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un disco de destino se llenó durante la copia. Libera espacio e inténtalo de nuevo. La tarjeta está intacta: mantenla como está."
          }
        }
      }
    },
    "error.offload.permissionDenied": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O macOS bloqueou o acesso à pasta de destino. Libere em Ajustes › Privacidade › Arquivos e Pastas e tente de novo. O cartão está intocado."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS blocked access to the destination folder. Allow it in Settings › Privacy › Files and Folders and try again. The card is untouched."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS bloqueó el acceso a la carpeta de destino. Permítelo en Ajustes › Privacidad › Archivos y carpetas e inténtalo de nuevo. La tarjeta está intacta."
          }
        }
      }
    },
    "error.naming.unknownToken %@": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O preset usa um campo desconhecido: “%@”. Revise a estrutura de pastas ou o padrão de nome."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The preset uses an unknown field: “%@”. Review the folder structure or the naming pattern."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El preset usa un campo desconocido: “%@”. Revisa la estructura de carpetas o el patrón de nombre."
          }
        }
      }
    },
    "error.naming.unknownModifier %@": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O preset usa um modificador desconhecido: “%@”."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The preset uses an unknown modifier: “%@”."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El preset usa un modificador desconocido: “%@”."
          }
        }
      }
    },
    "error.naming.pathTraversal": {
      "localizations": {
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A estrutura de pastas do preset é inválida — ela não pode sair da pasta de destino."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The preset’s folder structure is invalid — it can’t leave the destination folder."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La estructura de carpetas del preset es inválida: no puede salir de la carpeta de destino."
          }
        }
      }
    }
  },
  "version": "1.0"
}

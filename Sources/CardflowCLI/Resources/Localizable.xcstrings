    "report.verdict.ok" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "✅ Everything verified on every destination. Safe to format the card."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "✅ Todo verificado en todos los destinos. Puedes formatear la tarjeta con seguridad."

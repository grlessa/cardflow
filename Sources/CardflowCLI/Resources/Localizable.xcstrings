    "cli.dryRun.nothingCopied" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "(dry-run) Nothing was copied."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "(dry-run) No se copió nada."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "(dry-run) Nada foi copiado."
          }
        }
      }
    },
    "cli.help" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "cardflow — verified card copy (the OffloadKit engine on the command line)\n\nusage:\n  cardflow --card <path> --to <destination> [--to <destination2>] \\\n           [--media tudo|foto|video|audio] [--camera <name>] [--evento <name>] \\\n           [--set field=value] [--rename] [--dry-run] [--yes] [--preset <file.cfp>]"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "cardflow — copia verificada de la tarjeta (el motor OffloadKit en la línea de comandos)\n\nuso:\n  cardflow --card <ruta> --to <destino> [--to <destino2>] \\\n           [--media tudo|foto|video|audio] [--camera <nombre>] [--evento <nombre>] \\\n           [--set campo=valor] [--rename] [--dry-run] [--yes] [--preset <archivo.cfp>]"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "cardflow — cópia verificada de cartão (motor OffloadKit na linha de comando)\n\nuso:\n  cardflow --card <caminho> --to <destino> [--to <destino2>] \\\n           [--media tudo|foto|video|audio] [--camera <nome>] [--evento <nome>] \\\n           [--set campo=valor] [--rename] [--dry-run] [--yes] [--preset <arquivo.cfp>]"
          }
        }
      }
    },
    "report.outcome.cardAlreadyCopied" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This card had already been copied (nothing new)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta tarjeta ya se había copiado (nada nuevo)."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este cartão já tinha sido copiado (nada novo)."
          }
        }
      }
    },
    "report.outcome.failures %@" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Failed: %@"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fallaron: %@"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Falharam: %@"
          }
        }
      }
    },
    "report.outcome.header %1$lld %2$lld %3$lld %4$lld" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verified: %1$lld · Skipped (already present): %2$lld · Failures: %3$lld · Sidecars: %4$lld"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verificados: %1$lld · Omitidos (ya existían): %2$lld · Fallos: %3$lld · Sidecars: %4$lld"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verificados: %1$lld · Pulados (já existiam): %2$lld · Falhas: %3$lld · Sidecars: %4$lld"
          }
        }
      }
    },
    "report.outcome.manifestFailures %@" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⚠️ Manifest NOT saved to: %@ (the media was verified; only the record failed — disk full / read-only?)"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⚠️ Manifiesto NO guardado en: %@ (el contenido se verificó; solo falló el registro — ¿disco lleno / solo lectura?)"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⚠️ Manifesto NÃO salvo em: %@ (a mídia foi verificada; só o registro falhou — disco cheio/somente-leitura?)"
          }
        }
      }
    },
    "report.outcome.manifestPath %@" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manifest: %@"

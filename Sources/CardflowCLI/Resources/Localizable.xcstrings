        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vai copiar: %1$@ = %2$lld arquivo(s), %3$@ por destino."
          }
        }
      }
    },
    "report.summary.unrecognized %@" : {
      "localizations" : {

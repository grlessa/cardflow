    "report.summary.totals %1$@ %2$lld %3$@" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Will copy: %1$@ = %2$lld file(s), %3$@ per destination."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se copiará: %1$@ = %2$lld archivo(s), %3$@ por destino."

{
  "sourceLanguage" : "pt-BR",
  "strings" : {
    "cli.abort.noSpace" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aborted: not enough space."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cancelado: espacio insuficiente."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abortado: espaço insuficiente."
          }
        }
      }
    },
    "cli.abort.sameDisk %@" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aborted: destinations on the same physical disk (%@) — the backup needs another disk."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cancelado: destinos en el mismo disco físico (%@) — el respaldo necesita otro disco."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abortado: destinos no mesmo disco físico (%@) — o backup precisa ser outro disco."
          }
        }
      }
    },

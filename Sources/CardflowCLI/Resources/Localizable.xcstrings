          }
        }
      }
    },
    "report.outcome.relocatedCinema %1$lld %2$@" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⚠️ %1$lld cinema clip(s) moved to avoid overwriting different footage (check the relink in the editor): %2$@"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⚠️ %1$lld clip(s) de cine movido(s) para no sobrescribir tomas distintas (revisa el revínculo en el editor): %2$@"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⚠️ %1$lld clipe(s) de cinema movido(s) pra evitar sobrescrever filmagem diferente (confira o relink no editor): %2$@"
          }
        }
      }
    },

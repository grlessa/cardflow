    "report.summary.shortfall %1$@ %2$@ %3$@" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "❌ No space on %1$@: needs %2$@, has %3$@."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "❌ Sin espacio en %1$@: necesita %2$@, tiene %3$@."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "❌ Sem espaço em %1$@: precisa %2$@, tem %3$@."
          }
        }
